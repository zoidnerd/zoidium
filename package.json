{
  "name": "zoidium",
  "version": "1.0.0",
  "description": "Offline Panzoid Clipmaker Gen3 mirror",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "web": "npx serve . -p 8123",
    "dev": "npx serve . -p 8123 & sleep 1 && open http://localhost:8123",
    "dist": "electron-builder",
    "export": "node tools/headless-export/cli.mjs"
  },
  "build": {
    "appId": "com.zoidium.app",
    "productName": "Zoidium",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js",
      "pz.all-35.css",
      "docs/**/*",
      "js/**/*",
      "effect/**/*",
      "effect-custom/**/*",
      "effect-custom-bezier-editor/**/*",
      "material/**/*",
      "worker/**/*",
      "assets/**/*",
      "fonts/**/*"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "serve": "^14.2.6",
    "serve-handler": "^6.1.7"
  }
}
