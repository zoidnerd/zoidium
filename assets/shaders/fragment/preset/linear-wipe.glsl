precision highp float; precision highp int; uniform sampler2D tDiffuse; varying vec2 vUvScaled; uniform float Transition_Completion; uniform float Wipe_Angle; uniform float Feather; uniform vec2 resolution; void main() { vec4 texel = texture2D(tDiffuse, vUvScaled); float completion = clamp(Transition_Completion / 100.0, 0.0, 1.0); float angle = radians(Wipe_Angle); vec2 dir = vec2(cos(angle), sin(angle)); vec2 uv = vUvScaled; float proj = dot(uv - 0.5, dir); float threshold = mix(-0.5, 0.5, completion); float featherNorm = Feather / max(resolution.x, resolution.y); float alpha = smoothstep(threshold - featherNorm, threshold + featherNorm, proj); gl_FragColor = texel * alpha; }
