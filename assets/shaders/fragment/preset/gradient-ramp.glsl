precision highp float; precision highp int; uniform sampler2D tDiffuse; varying vec2 vUvScaled; uniform vec2 Start_of_Ramp; uniform vec3 Start_Color; uniform vec2 End_of_Ramp; uniform vec3 End_Color; uniform int Ramp_Shape; uniform float Ramp_Scatter; uniform float Blend_With_Original; uniform int Swap_Colors; float hash(vec2 p) { return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453); } void main() { vec4 original = texture2D(tDiffuse, vUvScaled); vec3 colorA = (Swap_Colors == 1) ? End_Color : Start_Color; vec3 colorB = (Swap_Colors == 1) ? Start_Color : End_Color; float t; if (Ramp_Shape == 0) { vec2 dir = End_of_Ramp - Start_of_Ramp; float len = length(dir); t = dot(vUvScaled - Start_of_Ramp, normalize(dir)) / len; } else { float distStart = distance(vUvScaled, Start_of_Ramp); float distEnd = distance(End_of_Ramp, Start_of_Ramp); t = distStart / distEnd; } t = clamp(t, 0.0, 1.0); t += (hash(vUvScaled * 100.0) - 0.5) * Ramp_Scatter; t = clamp(t, 0.0, 1.0); vec3 gradientColor = mix(colorA, colorB, t); vec3 finalColor = mix(gradientColor, original.rgb, Blend_With_Original); gl_FragColor = vec4(finalColor, original.a); }
