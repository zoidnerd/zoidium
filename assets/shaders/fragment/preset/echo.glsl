precision highp float; uniform sampler2D tDiffuse; uniform vec2 resolution; varying vec2 vUv; uniform float echoTime; uniform int numEchoes; uniform float startIntensity; uniform float decay; uniform int echoOperator; vec4 blendColors(vec4 base, vec4 newColor, int mode) { if (mode == 0) return base + newColor; if (mode == 1) return max(base, newColor); if (mode == 2) return min(base, newColor); if (mode == 3) return 1.0 - (1.0 - base) * (1.0 - newColor); if (mode == 4) return newColor; if (mode == 5) return base; if (mode == 6) return mix(base, newColor, newColor.a); return base; } void main() { vec4 finalColor = vec4(0.0); float intensity = startIntensity; for (int i = 0; i < 100; i++) { if (i >= numEchoes) break; vec2 uvOffset = vUv - vec2(echoTime * float(i) * 0.1, 0.0); vec4 sampleColor = texture2D(tDiffuse, uvOffset) * intensity; finalColor = (i == 0) ? sampleColor : blendColors(finalColor, sampleColor, echoOperator); intensity *= decay; } gl_FragColor = finalColor; }
