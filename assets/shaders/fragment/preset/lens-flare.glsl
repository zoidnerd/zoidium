precision highp float; precision highp int; uniform sampler2D tDiffuse; varying vec2 vUvScaled; uniform vec2 Flare_Center; uniform float Flare_Brightness; uniform int Lens_Type; uniform float Blend_With_Original; uniform vec2 resolution; void main() { vec4 baseColor = texture2D(tDiffuse, vUvScaled); vec2 uv = vUvScaled; vec2 center = Flare_Center / resolution; vec2 diff = uv - center; float dist = length(diff); float glow = Flare_Brightness / (dist * 1.5 + 0.05); float streak = 0.0; if (Lens_Type == 0) streak = exp(-dist * 6.0); else if (Lens_Type == 1) streak = exp(-dist * 3.0); else if (Lens_Type == 2) streak = exp(-dist * 4.5); vec3 flareColor = vec3(glow + streak); float flareOpacity = 1.0 - Blend_With_Original; flareColor *= flareOpacity; vec3 combinedColor = baseColor.rgb + flareColor; gl_FragColor = vec4(combinedColor, 1.0); }
