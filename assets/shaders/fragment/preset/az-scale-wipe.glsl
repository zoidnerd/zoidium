precision highp float; precision highp int; uniform sampler2D tDiffuse; uniform vec2 uvScale; uniform vec2 resolution; varying vec2 vUvScaled; uniform float Stretch; uniform vec2 Center; uniform float Direction; vec4 sampleClamp(vec2 uv01) { vec2 u = clamp(uv01, vec2(0.0), vec2(1.0)); return texture2D(tDiffuse, u * uvScale); } void main() { vec2 uv = vUvScaled / uvScale; vec2 cPix = (max(Center.x, Center.y) > 2.0) ? Center : (Center * resolution); vec2 pPix = uv * resolution; vec2 r = pPix - cPix; float a = radians(Direction); vec2 dir = normalize(vec2(sin(a), cos(a))); vec2 perp = vec2(-dir.y, dir.x); float s = dot(r, dir); float t = dot(r, perp); float s0 = dot((vec2(0.0, 0.0) - cPix), dir); float s1 = dot((vec2(resolution.x, 0.0) - cPix), dir); float s2 = dot((vec2(0.0, resolution.y) - cPix), dir); float s3 = dot((vec2(resolution.x, resolution.y) - cPix), dir); float sMax = max(max(s0, s1), max(s2, s3)); float sMin = min(min(s0, s1), min(s2, s3)); float posExtent = max(sMax, 1e-5); float negExtent = max(-sMin, 1e-5); float side = (Stretch >= 0.0) ? 1.0 : -1.0; float u; if (side > 0.0) u = clamp(s / posExtent, 0.0, 1.0); else u = clamp((-s) / negExtent, 0.0, 1.0); float curve = 1.6; float uCurve = pow(u, curve); float amt = abs(Stretch); float factor = 1.0 + amt * uCurve; float sWarp = s; if (Stretch > 0.0) { if (s > 0.0) sWarp = s / factor; } else if (Stretch < 0.0) { if (s < 0.0) sWarp = s / factor; } float softPx = 1.5; float blend = smoothstep(0.0, softPx, s * side); float sFinal = mix(s, sWarp, blend); vec2 p2Pix = cPix + dir * sFinal + perp * t; vec2 uv2 = p2Pix / resolution; gl_FragColor = sampleClamp(uv2); }
