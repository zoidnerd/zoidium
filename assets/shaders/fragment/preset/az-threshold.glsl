precision highp float; precision highp int; uniform sampler2D tDiffuse; varying vec2 vUvScaled; uniform float Threshold; uniform float Channel; uniform float Invert; uniform float Blend_w_Original; float luminance709(vec3 c) { return dot(c, vec3(0.2126, 0.7152, 0.0722)); } float saturationHSV(vec3 c) { float mx = max(max(c.r, c.g), c.b); float mn = min(min(c.r, c.g), c.b); return (mx <= 0.0) ? 0.0 : (mx - mn) / mx; } void main() { vec4 texel = texture2D(tDiffuse, vUvScaled); float thr = clamp(Threshold, 0.0, 255.0) / 255.0; float inv = (Invert > 0.5) ? 1.0 : 0.0; float blend = clamp(Blend_w_Original, 0.0, 100.0) / 100.0; int ch = int(floor(Channel + 0.5)); vec4 effected = texel; if (ch == 0) { float v = luminance709(texel.rgb); float m = step(thr, v); m = mix(m, 1.0 - m, inv); effected = vec4(vec3(m), texel.a); } else if (ch == 1) { vec3 m = step(vec3(thr), texel.rgb); m = mix(m, vec3(1.0) - m, inv); effected = vec4(m, texel.a); } else if (ch == 2) { float s = saturationHSV(texel.rgb); float m = step(thr, s); m = mix(m, 1.0 - m, inv); effected = vec4(vec3(m), texel.a); } else { float m = step(thr, texel.a); m = mix(m, 1.0 - m, inv); effected = vec4(texel.rgb, m); } gl_FragColor = mix(effected, texel, blend); }
