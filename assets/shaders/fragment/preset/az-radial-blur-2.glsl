precision highp float; precision highp int; uniform sampler2D tDiffuse; varying vec2 vUvScaled; varying vec2 vUv; uniform vec2 resolution; uniform float Amount; uniform vec2 Center; uniform float Type; uniform float Antialiasing; uniform float Random_Seed; float gold_noise(vec2 coord, float seed) { return fract(sin(dot(coord.xy + seed, vec2(12.9898, 78.233))) * 43758.5453); } void main() { vec2 center = Center; float aspect = resolution.x / resolution.y; int samples = (Antialiasing > 0.5) ? 64 : 16; float strength = Amount * 0.01; vec4 accum = vec4(0.0); for (int i = 0; i < 64; i++) { if (i >= samples) break; float noise = gold_noise(vUv + float(i), Random_Seed); float t = (float(i) + noise) / float(samples); vec2 sampleUv; if (Type > 0.5) { float scale = 1.0 - (strength * t); sampleUv = center + (vUv - center) * scale; } else { float angle = strength * t * 2.0; float s = sin(angle); float c = cos(angle); vec2 rel = vUv - center; rel.x *= aspect; vec2 rotated; rotated.x = rel.x * c - rel.y * s; rotated.y = rel.x * s + rel.y * c; rotated.x /= aspect; sampleUv = rotated + center; } accum += texture2D(tDiffuse, sampleUv); } gl_FragColor = accum / float(samples); }
