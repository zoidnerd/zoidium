precision highp float; precision highp int; uniform sampler2D tDiffuse; uniform vec2 uvScale; uniform vec2 resolution; varying vec2 vUv; uniform float Field_Of_View; uniform float Reverse_Lens_Distortion; uniform float FOV_Orientation; uniform vec2 View_Center; uniform float Optimal_Pixels; uniform float Resize; float sat(float x) { return clamp(x, 0.0, 1.0); } vec2 toBufferUV(vec2 uv01) { return uv01 * uvScale; } bool in01(vec2 uv) { return (uv.x >= 0.0 && uv.x <= 1.0 && uv.y >= 0.0 && uv.y <= 1.0); } float refRadiusPx(float orient) { if (orient < 0.5) return 0.5 * resolution.x; if (orient < 1.5) return 0.5 * resolution.y; return 0.5 * length(resolution); } vec2 opticsMap(vec2 outUV01) { float fovDeg = clamp(Field_Of_View, 0.0, 179.999); if (fovDeg <= 0.00001) return outUV01; vec2 centerPx = View_Center; float refPx = max(1.0, refRadiusPx(FOV_Orientation)); vec2 outPx = outUV01 * resolution; vec2 dPx = outPx - centerPx; vec2 p = dPx / refPx; float r = length(p); if (r <= 1e-7) return outUV01; float a = radians(fovDeg) * 0.5; float r2; float ta = tan(a); if (Reverse_Lens_Distortion < 0.5) { r2 = tan(r * a) / max(1e-8, ta); } else { r2 = atan(r * ta) / max(1e-8, a); } vec2 p2 = p * (r2 / r); vec2 srcPx = centerPx + p2 * refPx; return srcPx / resolution; } vec2 applyScale(vec2 srcUV01, float scale) { vec2 centerUV = View_Center / resolution; return centerUV + (srcUV01 - centerUV) / max(1.0, scale); } float maxScaleFromResize() { if (Reverse_Lens_Distortion < 0.5) return 1.0; if (Resize < 0.5) return 1.0; if (Resize < 1.5) return 2.0; if (Resize < 2.5) return 4.0; return 16.0; } float computeAutoScale(float maxScaleAllowed) { bool wantScale = (Optimal_Pixels > 0.5) || (maxScaleAllowed > 1.0001); if (!wantScale) return 1.0; float lo = 1.0; float hi = maxScaleAllowed; for (int i = 0; i < 10; i++) { float mid = 0.5 * (lo + hi); vec2 s0 = applyScale(opticsMap(vec2(0.0, 0.0)), mid); vec2 s1 = applyScale(opticsMap(vec2(1.0, 0.0)), mid); vec2 s2 = applyScale(opticsMap(vec2(0.0, 1.0)), mid); vec2 s3 = applyScale(opticsMap(vec2(1.0, 1.0)), mid); bool ok = in01(s0) && in01(s1) && in01(s2) && in01(s3); if (ok) hi = mid; else lo = mid; } return hi; } void main() { vec2 outUV = vUv; vec2 srcUV = opticsMap(outUV); float maxScale = maxScaleFromResize(); float scale = computeAutoScale(maxScale); srcUV = applyScale(srcUV, scale); if (!in01(srcUV)) { gl_FragColor = vec4(0.0); return; } gl_FragColor = texture2D(tDiffuse, toBufferUV(srcUV)); }
