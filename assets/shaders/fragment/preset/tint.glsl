precision highp float; precision highp int; uniform sampler2D tDiffuse; varying vec2 vUvScaled; uniform vec3 Map_Black_To; uniform vec3 Map_White_To; uniform float Amount_to_Tint; uniform float Swap_Colors; float getLuma(vec3 c) { return dot(c, vec3(0.299, 0.587, 0.114)); } void main() { vec4 texel = texture2D(tDiffuse, vUvScaled); float amt = clamp(Amount_to_Tint, 0.0, 100.0) / 100.0; float s = step(0.5, Swap_Colors); vec3 blackMap = mix(Map_Black_To, Map_White_To, s); vec3 whiteMap = mix(Map_White_To, Map_Black_To, s); float luma = clamp(getLuma(texel.rgb), 0.0, 1.0); vec3 tinted = mix(blackMap, whiteMap, luma); vec3 outRgb = mix(texel.rgb, tinted, amt); gl_FragColor = vec4(outRgb, texel.a); }
