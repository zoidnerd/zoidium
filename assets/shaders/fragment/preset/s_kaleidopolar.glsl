precision highp float; precision highp int; uniform sampler2D tDiffuse; uniform vec2 uvScale; uniform vec2 resolution; varying vec2 vUvScaled; uniform vec2 Center_XY; uniform float Z_Dist; uniform float Rotate; uniform float Stretch_X; uniform float Stretch_Y; uniform float Inside_Shift_Y; uniform float Angle_Repeats; uniform float Kaleido_Amount; const float PI = 3.14159265358979323846; const float TAU = 6.28318530717958647692; float safeInv(float x) { return 1.0 / max(abs(x), 1e-6); } void main() { vec2 uv = vUvScaled / uvScale; vec2 centerUV = vec2( Center_XY.x / resolution.x, 1.0 - (Center_XY.y / resolution.y) ); vec2 p = (uv - centerUV) * resolution; p.x *= safeInv(Stretch_X); p.y *= safeInv(Stretch_Y); float r = length(p); float ang = atan(p.y, p.x); ang += radians(Rotate); ang = mod(ang + TAU, TAU); float reps = max(Angle_Repeats, 1.0); float sector = TAU / reps; float halfSector = 0.5 * sector; float a = mod(ang, sector); a = abs(a - halfSector); float uPolar = a / max(halfSector, 1e-6); float radiusBase = 0.5 * min(resolution.x, resolution.y); float vPolar = (r * Z_Dist - Inside_Shift_Y) / max(radiusBase, 1e-6); vec2 uvPolar = vec2(uPolar, vPolar); float amt = Kaleido_Amount; vec2 uvFinal = uv + (uvPolar - uv) * amt; uvFinal = fract(uvFinal); gl_FragColor = texture2D(tDiffuse, uvFinal * uvScale); }
