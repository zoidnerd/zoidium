precision highp float; precision highp int; uniform sampler2D tDiffuse; varying vec2 vUvScaled; varying vec2 vUv; uniform vec2 resolution; uniform float Transition_Completion; uniform float Direction; uniform float Width; uniform float Feather; void main() { vec2 uv = vUv; float aspect = resolution.x / resolution.y; float angle = radians(Direction); float s = sin(angle); float c = cos(angle); vec2 centeredUv = uv - 0.5; centeredUv.x *= aspect; vec2 rotUv; rotUv.x = centeredUv.x * c - centeredUv.y * s; rotUv.y = centeredUv.x * s + centeredUv.y * c; float slatSize = max(Width, 1.0) / resolution.y; float val = (rotUv.x / slatSize) + 100.0; float fraction = fract(val); float dist = abs(fraction - 0.5); float fRatio = (Feather / max(Width, 1.0)) * 0.5; float maxVisible = 0.5 + fRatio; float minVisible = 0.0 - fRatio; float progress = Transition_Completion / 100.0; float currentThreshold = mix(maxVisible, minVisible, progress); float mask = 1.0 - smoothstep(currentThreshold - fRatio, currentThreshold + fRatio, dist); vec4 texel = texture2D(tDiffuse, vUvScaled); gl_FragColor = texel * mask; }
