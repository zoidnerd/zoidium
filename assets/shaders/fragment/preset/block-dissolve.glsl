precision highp float; precision highp int; uniform sampler2D tDiffuse; uniform vec2 uvScale; uniform vec2 resolution; uniform float Transition_Completion; uniform float Block_Width; uniform float Block_Height; uniform float Feather; uniform float Soft_Edges; varying vec2 vUvScaled; varying vec2 vUv; float rand(vec2 p) { vec3 p3 = fract(vec3(p.xyx) * 0.1031); p3 += dot(p3, p3.yzx + 33.33); return fract((p3.x + p3.y) * p3.z); } void main() { vec4 texel = texture2D(tDiffuse, vUvScaled); vec2 res = max(resolution, vec2(1.0)); vec2 fragCoord = vUv * res; float bWidth = max(Block_Width, 1.0); float bHeight = max(Block_Height, 1.0); vec2 blockSize = vec2(bWidth, bHeight); vec2 gridPos = fragCoord / blockSize; vec2 blockId = floor(gridPos); vec2 blockFract = fract(gridPos); float noiseVal = rand(blockId); float completion = clamp(Transition_Completion / 100.0, 0.0, 1.0); float featherNorm = clamp(Feather / 100.0, 0.0, 1.0); if (Soft_Edges > 0.5 || featherNorm > 0.0) { float n00 = noiseVal; float n10 = rand(blockId + vec2(1.0, 0.0)); float n01 = rand(blockId + vec2(0.0, 1.0)); float n11 = rand(blockId + vec2(1.0, 1.0)); vec2 u = blockFract; if (Soft_Edges > 0.5) { u = u * u * (3.0 - 2.0 * u); } float interpolatedNoise = mix( mix(n00, n10, u.x), mix(n01, n11, u.x), u.y ); float mixFactor = clamp(featherNorm * 2.0, 0.0, 1.0); if (featherNorm == 0.0 && Soft_Edges > 0.5) { mixFactor = 0.05; } noiseVal = mix(noiseVal, interpolatedNoise, mixFactor); } float alpha = 1.0; float spread = featherNorm; if (Soft_Edges > 0.5 && spread < 0.01) { spread = 0.01; } if (spread > 0.0) { float c = completion * (1.0 + 2.0 * spread) - spread; alpha = smoothstep(c - spread, c + spread, noiseVal); } else { alpha = step(completion, noiseVal); if (completion <= 0.0) { alpha = 1.0; } else if (completion >= 1.0) { alpha = 0.0; } } gl_FragColor = vec4(texel.rgb, texel.a * alpha); }
