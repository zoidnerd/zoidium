precision highp float; precision highp int; uniform sampler2D tDiffuse; uniform vec2 resolution; varying vec2 vUvScaled; uniform float Amount; uniform float Radius; uniform float Threshold; vec3 gaussianBlur(vec2 uv, float radiusPx) { if (radiusPx <= 0.0) return texture2D(tDiffuse, uv).rgb; const int K = 6; float sigma = max(radiusPx, 0.001); float stepPx = max(1.0, radiusPx / float(K)); vec2 texel = 1.0 / resolution; vec3 acc = texture2D(tDiffuse, uv).rgb; float wsum = 1.0; for (int i = 1; i <= K; ++i) { float d = float(i) * stepPx; float w = exp(-(d*d) / (2.0 * sigma * sigma)); vec2 off = texel * d; acc += texture2D(tDiffuse, uv + vec2( off.x, 0.0)).rgb * w; acc += texture2D(tDiffuse, uv + vec2(-off.x, 0.0)).rgb * w; acc += texture2D(tDiffuse, uv + vec2(0.0, off.y)).rgb * w; acc += texture2D(tDiffuse, uv + vec2(0.0, -off.y)).rgb * w; wsum += 4.0 * w; } return acc / wsum; } float luma709(vec3 c) { return dot(c, vec3(0.2126, 0.7152, 0.0722)); } void main() { vec2 uv = vUvScaled; vec3 src = texture2D(tDiffuse, uv).rgb; float r = max(Radius, 0.0); vec3 blur = gaussianBlur(uv, r); vec3 hp = src - blur; float thr = clamp(Threshold / 255.0, 0.0, 1.0); float edgeStrength = abs(luma709(hp)); float gate = smoothstep(thr, thr + (1.0/255.0), edgeStrength); float gain = Amount / 100.0; vec3 outColor = src + hp * gain * gate; gl_FragColor = vec4(clamp(outColor, 0.0, 1.0), 1.0); }
