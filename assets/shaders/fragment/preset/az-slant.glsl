precision highp float; precision highp int; uniform sampler2D tDiffuse; uniform vec2 uvScale; uniform vec2 resolution; varying vec2 vUv; varying vec2 vUvScaled; uniform float Slant; uniform float Stretching; uniform float Height; uniform vec2 Floor; uniform float Set_Color; uniform vec3 Color; float safeSign(float v) { return (v < 0.0) ? -1.0 : 1.0; } bool inside01(vec2 uv) { return uv.x >= 0.0 && uv.x <= 1.0 && uv.y >= 0.0 && uv.y <= 1.0; } void main() { vec2 uv = vUv; vec2 floorUv = vec2( Floor.x / resolution.x, 1.0 - (Floor.y / resolution.y) ); float angle = radians(Slant); float s = sin(angle); float c = cos(angle); float h = Height / 100.0; float eps = 0.0001; float safeC = (abs(c) < eps) ? (eps * safeSign(c)) : c; float safeH = (abs(h) < eps) ? (eps * safeSign(h)) : h; float safeTan = s / safeC; vec2 d = uv - floorUv; vec2 srcRel; if (Stretching >= 0.5) { srcRel = vec2( d.x - d.y * safeTan, d.y / safeH ); } else { srcRel = vec2( d.x - d.y * safeTan, d.y / (safeH * safeC) ); } vec2 srcUv = floorUv + srcRel; vec4 outColor = vec4(0.0); if (inside01(srcUv)) { vec4 texel = texture2D(tDiffuse, srcUv * uvScale); if (Set_Color >= 0.5) { outColor = vec4(Color, texel.a); } else { outColor = texel; } } gl_FragColor = outColor; }
