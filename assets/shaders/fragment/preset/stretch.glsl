precision highp float; precision highp int; uniform sampler2D tDiffuse; uniform vec2 resolution; uniform vec2 uvScale; varying vec2 vUv; uniform vec2 Anchor_Point; uniform float Angle; uniform float Shift_Amount; uniform float Direction; void main() { vec2 p = vUv * resolution; vec2 anchor = vec2(Anchor_Point.x, resolution.y - Anchor_Point.y); float rad = radians(Angle); vec2 dir = vec2(sin(rad), cos(rad)); vec2 diff = p - anchor; float dist = dot(diff, dir); float S = clamp(abs(Shift_Amount), 0.0, 10000.0); float dist_src = dist; if (Direction < 0.5) { if (dist > S) { dist_src = dist - S; } else if (dist < -S) { dist_src = dist + S; } else { dist_src = 0.0; } } else if (Direction < 1.5) { if (dist > S) { dist_src = dist - S; } else if (dist > 0.0) { dist_src = 0.0; } else { dist_src = dist; } } else { if (dist < -S) { dist_src = dist + S; } else if (dist < 0.0) { dist_src = 0.0; } else { dist_src = dist; } } vec2 p_src = p + dir * (dist_src - dist); vec2 uv_src = p_src / resolution; vec4 texel = texture2D(tDiffuse, uv_src * uvScale); gl_FragColor = texel; }
