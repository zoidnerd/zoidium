precision highp float; uniform sampler2D tDiffuse; uniform vec2 resolution; varying vec2 vUv; uniform vec2 reflectionCenter; uniform float reflectionAngle; void main() { float angle = radians(reflectionAngle); vec2 uvPx = vUv * resolution; vec2 centered = uvPx - reflectionCenter; float cosA = cos(-angle); float sinA = sin(-angle); vec2 rotated = vec2( centered.x * cosA - centered.y * sinA, centered.x * sinA + centered.y * cosA ); rotated.x = abs(rotated.x); vec2 unrotated = vec2( rotated.x * cosA + rotated.y * sinA, -rotated.x * sinA + rotated.y * cosA ); vec2 mirroredPx = unrotated + reflectionCenter; vec2 mirroredUV = mirroredPx / resolution; vec4 color = texture2D(tDiffuse, mirroredUV); gl_FragColor = color; }
