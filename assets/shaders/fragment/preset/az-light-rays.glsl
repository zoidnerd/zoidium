precision highp float; precision highp int; uniform sampler2D tDiffuse; uniform vec2 resolution; varying vec2 vUvScaled; uniform float Intensity; uniform vec2 Center; uniform float Radius; uniform float Warp_Softness; uniform int Shape; uniform float Direction; uniform int Color_from_Source; uniform int Allow_Brightening; uniform vec3 Color; uniform int Transfer_Mode; #define SAMPLES 64 float getShapeMask(vec2 samplePosPx, vec2 centerPx, float r, float softness, int shapeType, float angle) { vec2 p = samplePosPx - centerPx; float dist = 0.0; if (shapeType == 0) { dist = length(p); } else { float rad = radians(angle); float s = sin(rad); float c = cos(rad); vec2 pRot = vec2(p.x * c - p.y * s, p.x * s + p.y * c); dist = max(abs(pRot.x), abs(pRot.y)); } float soft = clamp(softness, 0.0, max(r, 0.0)); return 1.0 - smoothstep(r - soft, r, dist); } float getShapeDist(vec2 posPx, vec2 centerPx, int shapeType, float angle) { vec2 p = posPx - centerPx; if (shapeType == 0) { return length(p); } else { float rad = radians(angle); float s = sin(rad); float c = cos(rad); vec2 pRot = vec2(p.x * c - p.y * s, p.x * s + p.y * c); return max(abs(pRot.x), abs(pRot.y)); } } void main() { vec2 uv = vUvScaled; vec2 centerUV = Center / resolution; vec2 dir = centerUV - uv; vec2 delta = dir / float(SAMPLES); vec3 accColor = vec3(0.0); vec2 sampleUV = uv; for(int i = 0; i < SAMPLES; i++) { sampleUV += delta; vec4 sampleTex = texture2D(tDiffuse, sampleUV); vec3 sampleLight = sampleTex.rgb; if (Color_from_Source == 0) { float luma = dot(sampleLight, vec3(0.299, 0.587, 0.114)); sampleLight = Color * luma; } vec2 samplePx = sampleUV * resolution; float mask = getShapeMask(samplePx, Center, Radius, Warp_Softness, Shape, Direction); accColor += sampleLight * mask; } vec3 rayColor = (accColor / float(SAMPLES)) * (Intensity * 0.05); vec4 original = texture2D(tDiffuse, uv); vec3 finalColor = original.rgb; if (Transfer_Mode == 0) { finalColor = rayColor; } else if (Transfer_Mode == 1) { finalColor += rayColor; } else if (Transfer_Mode == 2) { finalColor = max(finalColor, rayColor); } else if (Transfer_Mode == 3) { finalColor = 1.0 - (1.0 - finalColor) * (1.0 - rayColor); } if (Allow_Brightening == 0 && Color_from_Source == 1 && Transfer_Mode != 0) { vec2 thisPx = uv * resolution; float d = getShapeDist(thisPx, Center, Shape, Direction); float soft = clamp(Warp_Softness, 0.0, max(Radius, 0.0)); float coreR = max(Radius - soft, 0.0); float edge = 1.0; float coreMask = 1.0 - smoothstep(coreR - edge, coreR + edge, d); finalColor = mix(finalColor, original.rgb, coreMask); } gl_FragColor = vec4(finalColor, original.a); }
