precision highp float; precision highp int; uniform sampler2D tDiffuse; uniform vec2 resolution; uniform vec2 uvScale; varying vec2 vUv; varying vec2 vUvScaled; uniform float Scale; uniform vec2 Center; uniform float Blend_With_Original; vec2 wrap01(vec2 uv) { return fract(uv); } void main() { vec4 original = texture2D(tDiffuse, vUvScaled); vec2 centerUv = Center / resolution; float s = max(Scale, 0.0001); float factor = 100.0 / s; vec2 uv = vUv; vec2 tiledUv = (uv - centerUv) * factor + centerUv; tiledUv = wrap01(tiledUv); vec4 tiled = texture2D(tDiffuse, tiledUv * uvScale); float blend = clamp(Blend_With_Original / 100.0, 0.0, 1.0); gl_FragColor = mix(tiled, original, blend); }
