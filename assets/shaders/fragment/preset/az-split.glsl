precision highp float; precision highp int; uniform sampler2D tDiffuse; uniform vec2 resolution; uniform vec2 uvScale; varying vec2 vUv; varying vec2 vUvScaled; uniform vec2 Point_A; uniform vec2 Point_B; uniform float Split; vec4 sampleLayer(vec2 uv) { if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return vec4(0.0); return texture2D(tDiffuse, uv * uvScale); } void main() { float splitAbs = abs(Split); if (splitAbs < 1e-4) { gl_FragColor = texture2D(tDiffuse, vUvScaled); return; } vec2 A = Point_A; vec2 B = Point_B; vec2 d = B - A; float L = length(d); if (L < 1e-5) { gl_FragColor = texture2D(tDiffuse, vUvScaled); return; } vec2 p = vUv * resolution; vec2 t = d / L; vec2 n = normalize(vec2(-t.y, t.x)); float u = dot(p - A, t); float s = u / L; float distN = dot(p - A, n); float absDistN = abs(distN); float sgn = (distN >= 0.0) ? 1.0 : -1.0; float taperPx = clamp(0.12 * L, 18.0, 90.0); float segMask = step(0.0, u) * step(u, L); float endMask = smoothstep(0.0, taperPx, u) * smoothstep(0.0, taperPx, (L - u)); segMask *= endMask; float sc = clamp(s, 0.0, 1.0); float profile = sin(3.14159265 * sc); profile = pow(max(profile, 0.0), 2.6); profile *= segMask; float gapHalf = 0.5 * Split * profile; float sigma = max(1.0, splitAbs * 0.65); float influence = exp(-absDistN / sigma); float disp = gapHalf * influence; vec2 sampleUv = (p - n * disp * sgn) / resolution; vec4 col = sampleLayer(sampleUv); float aa = 1.25; float outsideGap = smoothstep(gapHalf - aa, gapHalf + aa, absDistN); float gapMask = mix(1.0, outsideGap, segMask); gl_FragColor = col * gapMask; }
