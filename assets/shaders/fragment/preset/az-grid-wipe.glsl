precision highp float; precision highp int; uniform sampler2D tDiffuse; uniform vec2 resolution; uniform vec2 uvScale; varying vec2 vUvScaled; uniform float Completion; uniform vec2 Center; uniform float Rotation; uniform float Borders; uniform float Tiles; uniform float Shape; uniform bool Reverse_Transition; #define SHAPE_DOORS 0 #define SHAPE_RADIAL 1 #define SHAPE_RECT 2 void main() { vec2 uv = vUvScaled; float aspect = resolution.x / resolution.y; float comp = clamp(Completion / 100.0, 0.0, 1.0); float nTiles = max(1.0, Tiles); int shapeType = int(Shape + 0.5); vec2 centerUV = Center / resolution; if (Center.x == 0.0 && Center.y == 0.0) centerUV = vec2(0.5, 0.5); vec2 p = uv; p.x *= aspect; vec2 c = centerUV; c.x *= aspect; float ang = radians(Rotation); float s = sin(ang); float cA = cos(ang); vec2 delta = p - c; vec2 pRot = vec2( delta.x * cA - delta.y * s, delta.x * s + delta.y * cA ) + c; vec2 gridPos = pRot * nTiles; vec2 tileId = floor(gridPos); vec2 tileUv = fract(gridPos) - 0.5; vec2 tileCenterPos = (tileId + 0.5) / nTiles; float d1 = distance(vec2(0.0, 0.0), c); float d2 = distance(vec2(aspect, 0.0), c); float d3 = distance(vec2(0.0, 1.0), c); float d4 = distance(vec2(aspect, 1.0), c); float maxDist = max(max(d1, d2), max(d3, d4)); float dist = distance(tileCenterPos, c); if (Reverse_Transition) { dist = maxDist - dist; } float borderW = max(0.001, Borders * 0.015); float startCut = -borderW; float endCut = maxDist; float cutPos = mix(startCut, endCut, comp); float scale = smoothstep(cutPos, cutPos + borderW, dist); float sdf = 0.0; float maxRadius = 0.5; float overlap = 0.05; if (shapeType == SHAPE_DOORS) { sdf = abs(tileUv.x) + abs(tileUv.y); maxRadius = 1.0 + overlap; } else if (shapeType == SHAPE_RADIAL) { sdf = length(tileUv); maxRadius = 0.75 + overlap; } else { sdf = max(abs(tileUv.x), abs(tileUv.y)); maxRadius = 0.5 + overlap; } float currentSize = scale * maxRadius; float aa = 0.01; float alpha = 1.0 - smoothstep(currentSize - aa, currentSize, sdf); if (comp <= 0.0) alpha = 1.0; vec4 texel = texture2D(tDiffuse, vUvScaled); gl_FragColor = texel * alpha; }
