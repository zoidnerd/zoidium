precision highp float; precision highp int; uniform sampler2D tDiffuse; uniform vec2 resolution; uniform vec2 uvScale; varying vec2 vUv; varying vec2 vUvScaled; uniform float Shift; uniform float Width; uniform float Number_of_Slices; uniform vec2 Anchor_Point; uniform float Angle; uniform float Seed; float rand(float n) { return fract(sin(n) * 43758.5453123); } void main() { vec2 pixelPos = vUv * resolution; vec2 pos = pixelPos - Anchor_Point; float rad = radians(Angle); float c = cos(rad); float s = sin(rad); mat2 rot = mat2(c, -s, s, c); vec2 rotatedPos = rot * pos; float maxDim = max(resolution.x, resolution.y) * 2.0; float safeSlices = max(Number_of_Slices, 1.0); float sliceThickness = maxDim / safeSlices; float sliceIndex = floor(rotatedPos.y / sliceThickness); float randomVal = rand(sliceIndex + (Seed * 123.456)); float currentShift = Shift * (randomVal * 2.0 - 1.0); rotatedPos.x -= currentShift; float localY = mod(rotatedPos.y, sliceThickness); float visibleThickness = sliceThickness * (Width / 100.0); mat2 invRot = mat2(c, s, -s, c); vec2 newPos = invRot * rotatedPos; newPos += Anchor_Point; vec2 finalUv = newPos / resolution; if (finalUv.x < 0.0 || finalUv.x > 1.0 || finalUv.y < 0.0 || finalUv.y > 1.0 || localY > visibleThickness) { gl_FragColor = vec4(0.0); } else { gl_FragColor = texture2D(tDiffuse, finalUv * uvScale); } }
