precision highp float; uniform sampler2D tDiffuse; uniform vec2 resolution; varying vec2 vUv; uniform float angle; uniform float twirlRadius; uniform vec2 twirlCenter; void main() { vec2 uvPx = vUv * resolution; vec2 delta = uvPx - twirlCenter; float dist = length(delta); if (dist > twirlRadius) { gl_FragColor = texture2D(tDiffuse, vUv); return; } float normDist = dist / twirlRadius; float maxAngle = radians(angle); float twist = maxAngle * (1.0 - normDist); float cosT = cos(twist); float sinT = sin(twist); vec2 rotated = vec2( delta.x * cosT - delta.y * sinT, delta.x * sinT + delta.y * cosT ); vec2 finalPx = twirlCenter + rotated; vec2 finalUV = finalPx / resolution; gl_FragColor = texture2D(tDiffuse, finalUV); }
