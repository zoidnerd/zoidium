precision highp float; precision highp int; #ifdef GL_EXT_shader_texture_lod #extension GL_EXT_shader_texture_lod : enable #endif uniform sampler2D tDiffuse; uniform vec2 uvScale; uniform vec2 resolution; varying vec2 vUvScaled; uniform float Horizontal_Blocks; uniform float Vertical_Blocks; uniform float Sharp_Colors; #define AVG_GRID 4 #define USE_LINEAR_LIGHT 0 vec3 toLinear(vec3 c) { return pow(c, vec3(2.2)); } vec3 toGamma(vec3 c) { return pow(c, vec3(1.0 / 2.2)); } vec4 sampleBuffer(vec2 layerUV) { return texture2D(tDiffuse, layerUV * uvScale); } vec2 snapToTexelCenter(vec2 bufferUV) { vec2 px = bufferUV * resolution; px = floor(px) + 0.5; return px / resolution; } void main() { vec2 uv = vUvScaled / uvScale; uv = clamp(uv, 0.0, 0.999999); vec2 blocks = vec2(max(1.0, Horizontal_Blocks), max(1.0, Vertical_Blocks)); vec2 cellSize = 1.0 / blocks; vec2 cell = floor(uv * blocks); vec2 centerUV = (cell + 0.5) * cellSize; centerUV = clamp(centerUV, 0.0, 0.999999); if (Sharp_Colors >= 0.5) { vec2 centerBuf = snapToTexelCenter(centerUV * uvScale); gl_FragColor = texture2D(tDiffuse, centerBuf); return; } #ifdef GL_EXT_shader_texture_lod vec2 gradX = vec2(cellSize.x, 0.0) * uvScale; vec2 gradY = vec2(0.0, cellSize.y) * uvScale; vec2 centerBufUV = centerUV * uvScale; vec4 c = texture2DGradEXT(tDiffuse, centerBufUV, gradX, gradY); #if USE_LINEAR_LIGHT c.rgb = toGamma(toLinear(c.rgb)); #endif gl_FragColor = c; return; #endif vec2 baseUV = cell * cellSize; vec3 accRGB = vec3(0.0); float accA = 0.0; for (int y = 0; y < AVG_GRID; y++) { for (int x = 0; x < AVG_GRID; x++) { vec2 f = (vec2(float(x), float(y)) + 0.5) / float(AVG_GRID); vec2 suv = baseUV + f * cellSize; suv = clamp(suv, 0.0, 0.999999); vec2 bufUV = snapToTexelCenter(suv * uvScale); vec4 s = texture2D(tDiffuse, bufUV); #if USE_LINEAR_LIGHT accRGB += toLinear(s.rgb); #else accRGB += s.rgb; #endif accA += s.a; } } float invN = 1.0 / float(AVG_GRID * AVG_GRID); #if USE_LINEAR_LIGHT vec3 outRGB = toGamma(accRGB * invN); #else vec3 outRGB = accRGB * invN; #endif gl_FragColor = vec4(outRGB, accA * invN); }
